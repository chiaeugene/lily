# ───────────────────────────────────────────────────────────────
# Lily — environment variables
# Copy to .env.local and fill in. The app RUNS WITHOUT THESE in
# DEMO_MODE (seeded in-memory data) so you can see it working first.
# ───────────────────────────────────────────────────────────────

# Supabase (Project Settings -> API). When set, Lily uses Postgres
# instead of the in-memory demo store.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic / Claude — used by the Telegram bot to parse natural-language orders.
ANTHROPIC_API_KEY=
CLAUDE_PARSER_MODEL=claude-haiku-4-5-20251001

# Groq Whisper — transcribes Telegram VOICE notes to text (Mandarin/Malay/English).
# Get a key at https://console.groq.com . Without it, voice notes are ignored.
GROQ_API_KEY=
GROQ_STT_MODEL=whisper-large-v3

# Telegram bot (from @BotFather)
TELEGRAM_BOT_TOKEN=
# Comma-separated Telegram user IDs allowed to submit orders. Empty = allow all (dev only).
TELEGRAM_ALLOWED_USER_IDS=
# Secret path token for the webhook URL, e.g. set webhook to /api/telegram/<this>
TELEGRAM_WEBHOOK_SECRET=lily-hook

# Public base URL of this deployment (Render), used in bot replies / links.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Login gate. Defaults to 870333 if unset. TOKEN is the opaque value stored in
# the auth cookie (change it to invalidate all existing sessions).
LILY_PASSCODE=870333
LILY_AUTH_TOKEN=lily-authed
